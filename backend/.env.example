Learn more
# Gemini API
GEMINI_API_KEY="AIzaSyD7yL1G7wNmqsaJFx3CHbicLRRz1d_PZNM"
# Get your Gemini API key from: https://ai.google.dev

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_secure_jwt_secret_here
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Firebase
FIREBASE_PROJECT_ID=travler-planeer
# Note: Firebase credentials should only be used on the frontend (.env.local)
# Backend only needs the project ID if using Firebase Admin SDK for specific features

# CORS
# For Production: Set to your actual Vercel URL, or '*' to allow all (less secure)
# Example: CORS_ORIGIN=https://ai-quiz-silk.vercel.app
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI Provider Selection
# Options: custom (default), groq, gemini, ollama, mixed
# custom = In-house NLP model + optional LLM fine-tuning (no extra API key needed)
# mixed  = All providers generate questions that are blended together
AI_PROVIDER=custom

# Groq API (optional — used for fine-tuning the custom model's output)
GROQ_API_KEY=your_groq_api_key_here
# Get your key from: https://console.groq.com/settings/api-keys